{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shorevest.com/assets/data/recruitment/roles.v1.schema.json",
  "title": "ShoreVest recruitment role manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAtUtc",
    "emailApplication",
    "roles"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "roles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/role"
      }
    },
    "emailApplication": {
      "$ref": "#/$defs/emailApplication"
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "zh-CN"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3000
        },
        "zh-CN": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3000
        }
      }
    },
    "localizedArray": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "zh-CN"
      ],
      "properties": {
        "en": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        },
        "zh-CN": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "status",
        "contentReviewRequired",
        "contentReviewNote",
        "title",
        "location",
        "department",
        "reportingLine",
        "employmentType",
        "targetStartDate",
        "roleOverview",
        "responsibilities",
        "requiredQualifications",
        "preferredQualifications",
        "recruitmentStatus",
        "datePosted",
        "dateUpdated",
        "displayOrder",
        "application",
        "summary",
        "emailApplicationCopy"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
        },
        "status": {
          "enum": [
            "draft",
            "published",
            "closed"
          ]
        },
        "contentReviewRequired": {
          "type": "boolean"
        },
        "contentReviewNote": {
          "type": "string",
          "maxLength": 1000
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "location": {
          "$ref": "#/$defs/localizedText"
        },
        "department": {
          "$ref": "#/$defs/localizedText"
        },
        "reportingLine": {
          "$ref": "#/$defs/localizedText"
        },
        "employmentType": {
          "$ref": "#/$defs/localizedText"
        },
        "targetStartDate": {
          "$ref": "#/$defs/localizedText"
        },
        "roleOverview": {
          "$ref": "#/$defs/localizedText"
        },
        "responsibilities": {
          "$ref": "#/$defs/localizedArray"
        },
        "requiredQualifications": {
          "$ref": "#/$defs/localizedArray"
        },
        "preferredQualifications": {
          "$ref": "#/$defs/localizedArray"
        },
        "recruitmentStatus": {
          "$ref": "#/$defs/localizedText"
        },
        "datePosted": {
          "type": "string",
          "format": "date"
        },
        "dateUpdated": {
          "type": "string",
          "format": "date"
        },
        "displayOrder": {
          "type": "integer",
          "minimum": 1
        },
        "application": {
          "$ref": "#/$defs/application"
        },
        "summary": {
          "$ref": "#/$defs/localizedText"
        },
        "emailApplicationCopy": {
          "$ref": "#/$defs/emailApplicationCopy"
        }
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "deadlineUtc",
        "privacyNoticeVersion",
        "allowedSources",
        "cv"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "deadlineUtc": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "privacyNoticeVersion": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            {
              "type": "null"
            }
          ]
        },
        "allowedSources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "website",
              "linkedin",
              "direct",
              "other"
            ]
          }
        },
        "cv": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "maxSizeBytes",
            "allowedExtensions",
            "allowedMimeTypes"
          ],
          "properties": {
            "required": {
              "const": true
            },
            "maxSizeBytes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10485760
            },
            "allowedExtensions": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  ".pdf",
                  ".docx"
                ]
              }
            },
            "allowedMimeTypes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "application/pdf",
                  "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                ]
              }
            }
          }
        }
      }
    },
    "emailApplication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "address"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "address": {
          "type": "string",
          "format": "email",
          "maxLength": 254
        }
      }
    },
    "emailCopyLocale": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "heading",
        "copy",
        "button",
        "subject",
        "body"
      ],
      "properties": {
        "heading": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "copy": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "button": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "emailApplicationCopy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "zh-CN"
      ],
      "properties": {
        "en": {
          "$ref": "#/$defs/emailCopyLocale"
        },
        "zh-CN": {
          "$ref": "#/$defs/emailCopyLocale"
        }
      }
    }
  }
}
