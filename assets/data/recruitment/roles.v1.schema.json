{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shorevest.com/assets/data/recruitment/roles.v1.schema.json",
  "title": "ShoreVest recruitment role manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAtUtc",
    "roles"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "roles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/role"
      }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "zh-CN"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3000
        },
        "zh-CN": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3000
        }
      }
    },
    "localizedArray": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "zh-CN"
      ],
      "properties": {
        "en": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        },
        "zh-CN": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "status",
        "contentReviewRequired",
        "contentReviewNote",
        "title",
        "location",
        "department",
        "reportingLine",
        "employmentType",
        "targetStartDate",
        "roleOverview",
        "responsibilities",
        "requiredQualifications",
        "preferredQualifications",
        "recruitmentStatus",
        "datePosted",
        "dateUpdated",
        "displayOrder"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
        },
        "status": {
          "enum": [
            "draft",
            "published",
            "closed"
          ]
        },
        "contentReviewRequired": {
          "type": "boolean"
        },
        "contentReviewNote": {
          "type": "string",
          "maxLength": 1000
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "location": {
          "$ref": "#/$defs/localizedText"
        },
        "department": {
          "$ref": "#/$defs/localizedText"
        },
        "reportingLine": {
          "$ref": "#/$defs/localizedText"
        },
        "employmentType": {
          "$ref": "#/$defs/localizedText"
        },
        "targetStartDate": {
          "$ref": "#/$defs/localizedText"
        },
        "roleOverview": {
          "$ref": "#/$defs/localizedText"
        },
        "responsibilities": {
          "$ref": "#/$defs/localizedArray"
        },
        "requiredQualifications": {
          "$ref": "#/$defs/localizedArray"
        },
        "preferredQualifications": {
          "$ref": "#/$defs/localizedArray"
        },
        "recruitmentStatus": {
          "$ref": "#/$defs/localizedText"
        },
        "datePosted": {
          "type": "string",
          "format": "date"
        },
        "dateUpdated": {
          "type": "string",
          "format": "date"
        },
        "displayOrder": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
