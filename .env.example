# ShoreVest One — application environment (EXAMPLE).
# Copy to `.env` for local use. NEVER commit real secrets, tokens, tenant IDs,
# storage keys, or connection strings. Real values come from a secret manager
# (Azure Key Vault / environment injection) at deploy time.

# ── Environment mode ────────────────────────────────────────────────────────
# MOCK                 fictional animal data + mock connectors, no external writes
# CONNECTED_READ_ONLY  reads from approved external systems, no writes/execution
# CONNECTED_CONTROLLED approved writes + execution through permissioned workflows
SHOREVEST_ONE_MODE=MOCK

# ── Server ──────────────────────────────────────────────────────────────────
SHOREVEST_ONE_HOST=127.0.0.1
SHOREVEST_ONE_PORT=4319
# SQLite database file (MOCK/dev). In a connected deployment this becomes the
# managed database connection (see docs/shorevest-one/CONNECTORS.md).
SHOREVEST_ONE_DB=server/.data/shorevest-one.db

# ── Salesforce (future real connector) ──────────────────────────────────────
SF_INSTANCE_URL=
SF_CLIENT_ID=
# SF_CLIENT_SECRET / SF_PRIVATE_KEY come from the secret manager, not here.

# ── Microsoft Graph / Outlook (future real connector) ───────────────────────
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET comes from the secret manager.

# ── SharePoint (future real connector) ──────────────────────────────────────
SP_SITE_URL=

# ── Power Automate (future real connector) ──────────────────────────────────
PA_APPROVAL_FLOW_URL=
PA_EXECUTION_FLOW_URL=
