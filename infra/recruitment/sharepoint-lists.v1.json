{
  "schemaVersion": "1.2",
  "documentStorage": "azure-blob-only",
  "runtimePermission": "Lists.SelectedOperations.Selected",
  "lists": [
    {
      "name": "RecruitmentApplications",
      "template": "genericList",
      "description": "Restricted HR projection of finalized ShoreVest recruitment applications. This list contains metadata only and does not store CV files.",
      "keyField": "ApplicationReference",
      "indexedFields": [
        "ApplicationReference",
        "TechnicalStatus",
        "HiringStage",
        "RoleId",
        "CandidateEmail",
        "SubmittedAtServerUtc",
        "RetentionDeleteAfterUtc",
        "LegalHold"
      ],
      "columns": [
        { "name": "Title", "type": "text", "required": true, "readOnly": false },
        { "name": "ApplicationReference", "type": "text", "required": true, "enforceUniqueValues": true },
        { "name": "RoleId", "type": "text", "required": true },
        { "name": "RoleTitle", "type": "text", "required": true },
        { "name": "RoleDepartment", "type": "text", "required": false },
        { "name": "RoleLocation", "type": "text", "required": false },
        { "name": "Locale", "type": "choice", "required": true, "choices": ["en", "zh-CN"] },
        { "name": "Source", "type": "choice", "required": true, "choices": ["website", "linkedin", "direct", "other"] },
        { "name": "CandidateName", "type": "text", "required": true },
        { "name": "CandidateEmail", "type": "text", "required": false },
        { "name": "CandidateTelephone", "type": "text", "required": false },
        { "name": "CandidateLocation", "type": "text", "required": false },
        { "name": "LinkedInUrl", "type": "text", "required": false },
        { "name": "CoverNote", "type": "multilineText", "required": false, "allowMultipleLines": true, "appendChangesToExistingText": false },
        { "name": "PrivacyNoticeVersion", "type": "text", "required": true },
        { "name": "PrivacyAcceptedAtUtc", "type": "dateTime", "required": true, "format": "dateTime" },
        { "name": "InitiatedAtUtc", "type": "dateTime", "required": true, "format": "dateTime" },
        { "name": "SubmittedAtClientUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "SubmittedAtServerUtc", "type": "dateTime", "required": true, "format": "dateTime" },
        { "name": "FinalizedAtUtc", "type": "dateTime", "required": true, "format": "dateTime" },
        { "name": "AccuracyConfirmedAtUtc", "type": "dateTime", "required": true, "format": "dateTime" },
        { "name": "CandidateSubmissionStatus", "type": "choice", "required": true, "choices": ["Draft", "Submitted", "Deleted"] },
        { "name": "TechnicalStatus", "type": "choice", "required": true, "choices": ["Initiated", "UploadPending", "Received", "Scanning", "Ready", "ManualReview", "Blocked", "Incomplete", "Error", "Deleted"] },
        { "name": "HiringStage", "type": "choice", "required": true, "choices": ["New", "UnderReview", "Interview", "Hold", "Rejected", "Offer", "Hired", "Withdrawn", "Archived"] },
        { "name": "FileCount", "type": "number", "required": true, "decimalPlaces": 0 },
        { "name": "ReadyFileCount", "type": "number", "required": true, "decimalPlaces": 0 },
        { "name": "RequiresManualReview", "type": "boolean", "required": true },
        { "name": "RetentionReviewDate", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "RetentionCategory", "type": "choice", "required": false, "choices": ["Incomplete", "Submitted", "Malicious"] },
        { "name": "RetentionPolicyVersion", "type": "text", "required": false },
        { "name": "RetentionDeleteAfterUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "RetentionState", "type": "choice", "required": false, "choices": ["Active", "Processing", "Purged"] },
        { "name": "RetentionPurgedAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "LegalHold", "type": "boolean", "required": true, "defaultValue": false },
        { "name": "NotificationState", "type": "choice", "required": false, "choices": ["Pending", "Sending", "Sent", "Failed"] },
        { "name": "NotificationEventKey", "type": "text", "required": false },
        { "name": "NotificationSentAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "NotificationAttemptCount", "type": "number", "required": false, "decimalPlaces": 0 },
        { "name": "NotificationLastErrorCode", "type": "text", "required": false },
        { "name": "ApplicationReceivedNotificationState", "type": "choice", "required": false, "choices": ["Pending", "Sending", "Sent", "Failed"] },
        { "name": "ApplicationReceivedNotificationEventKey", "type": "text", "required": false },
        { "name": "ApplicationReceivedNotificationSentAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "ApplicationReceivedNotificationAttemptCount", "type": "number", "required": false, "decimalPlaces": 0 },
        { "name": "ApplicationReceivedNotificationLastErrorCode", "type": "text", "required": false },
        { "name": "DocumentsReadyNotificationState", "type": "choice", "required": false, "choices": ["Pending", "Sending", "Sent", "Failed"] },
        { "name": "DocumentsReadyNotificationEventKey", "type": "text", "required": false },
        { "name": "DocumentsReadyNotificationSentAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "DocumentsReadyNotificationAttemptCount", "type": "number", "required": false, "decimalPlaces": 0 },
        { "name": "DocumentsReadyNotificationLastErrorCode", "type": "text", "required": false },
        { "name": "LastUpdatedAtUtc", "type": "dateTime", "required": true, "format": "dateTime" }
      ]
    },
    {
      "name": "RecruitmentFiles",
      "template": "genericList",
      "description": "Restricted HR projection of recruitment file metadata. CV bytes remain in private Azure Blob Storage and are never stored in this list.",
      "keyField": "FileReference",
      "indexedFields": [
        "FileReference",
        "ApplicationReference",
        "TechnicalStatus",
        "ScanEventId",
        "RetentionDeleteAfterUtc",
        "LegalHold"
      ],
      "columns": [
        { "name": "Title", "type": "text", "required": true, "readOnly": false },
        { "name": "FileReference", "type": "text", "required": true, "enforceUniqueValues": true },
        { "name": "ApplicationReference", "type": "text", "required": true },
        { "name": "FilePurpose", "type": "choice", "required": true, "choices": ["CV", "CoverLetter", "SupportingDocument"] },
        { "name": "OriginalFileName", "type": "text", "required": true },
        { "name": "DeclaredMimeType", "type": "text", "required": true },
        { "name": "DetectedFileType", "type": "text", "required": false },
        { "name": "SizeBytes", "type": "number", "required": true, "decimalPlaces": 0 },
        { "name": "ExpectedHash", "type": "text", "required": false },
        { "name": "QuarantineBlobPath", "type": "text", "required": false },
        { "name": "CleanBlobPath", "type": "text", "required": false },
        { "name": "QuarantineRemovalPending", "type": "boolean", "required": true },
        { "name": "TechnicalStatus", "type": "choice", "required": true, "choices": ["SASIssued", "Uploaded", "ValidationFailed", "ScanPending", "Clean", "Ready", "Malicious", "ScanFailed", "ManualReview", "Removed"] },
        { "name": "ScanResult", "type": "choice", "required": false, "choices": ["Clean", "Malicious", "ScanFailed", "Unsupported", "Timeout"] },
        { "name": "ScanEventId", "type": "text", "required": false },
        { "name": "UploadVerifiedAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "ScanStartedAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "ScanCompletedAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "ReadyAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "QuarantineRemovedAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "RetentionReviewDate", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "RetentionCategory", "type": "choice", "required": false, "choices": ["Incomplete", "Submitted", "Malicious"] },
        { "name": "RetentionPolicyVersion", "type": "text", "required": false },
        { "name": "RetentionDeleteAfterUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "RetentionState", "type": "choice", "required": false, "choices": ["Active", "Processing", "Purged"] },
        { "name": "RetentionPurgedAtUtc", "type": "dateTime", "required": false, "format": "dateTime" },
        { "name": "LegalHold", "type": "boolean", "required": true, "defaultValue": false },
        { "name": "LastUpdatedAtUtc", "type": "dateTime", "required": true, "format": "dateTime" }
      ]
    }
  ]
}
